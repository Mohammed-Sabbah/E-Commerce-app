            { label: "My Profile", href: "/account" },
            { label: "Address Book", href: "/account/address" },
        ],
    },
    {
        section: "My Orders",
        links: [
            { label: "My Orders", href: "/account/orders" },
            { label: "My Cancellations", href: "/account/orders?filter=cancelled" },
        ],
    },
    {
        section: "My Reviews",
        links: [
            { label: "My Reviews", href: "/account/reviews" },
        ],
    },
    {
        section: "My WishList",
        links: [{ label: "My WishList", href: "/wishlist" }],
    },
];

export default function AccountSidebar() {
    const pathname = usePathname();

    // يقارن بالـ pathname فقط (بدون query params)
    function isActive(href: string) {
        const hrefPath = href.split("?")[0];
        return pathname === hrefPath;
    }

    return (
        <aside className="w-full lg:w-[220px] shrink-0">
            {navItems.map((group) => (
                <div key={group.section} className="mb-6">
                    <p className="font-semibold text-gray-900 mb-3">
